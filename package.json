{
  "name": "playmorrow",
  "version": "0.1.0",
  "private": true,
  "description": "Discover tomorrow's indie games today. The social discovery layer for indie games.",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @playmorrow/api dev",
    "dev:web": "pnpm --filter @playmorrow/web dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:all": "turbo run test && pnpm --filter @playmorrow/web test:e2e",
    "typecheck": "turbo run typecheck",
    "setup:env": "cp -n .env.example .env; cp -n apps/web/.env.example apps/web/.env.local; cp -n apps/api/.env.example apps/api/.env; cp -n packages/database/.env.example packages/database/.env; echo '✅ env files created (existing files left untouched). Set DATABASE_URL + JWT_SECRET.'",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "pnpm --filter @playmorrow/database db:generate",
    "db:migrate": "pnpm --filter @playmorrow/database db:migrate",
    "db:push": "pnpm --filter @playmorrow/database db:push",
    "db:studio": "pnpm --filter @playmorrow/database db:studio",
    "db:seed": "pnpm --filter @playmorrow/database db:seed",
    "admin:ensure": "tsx apps/api/src/admin-script.ts",
    "test:e2e": "pnpm --filter @playmorrow/web test:e2e",
    "loadtest": "pnpm --filter @playmorrow/api loadtest",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.9.6",
    "superpowers": "github:obra/superpowers",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^5.6.3"
  }
}
