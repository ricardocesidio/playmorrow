# Base URL of the Playmorrow API (NestJS). Used by the browser/server to fetch data.
# In production the Next.js rewrites in next.config.ts proxy /api/* to Railway.
# You usually leave NEXT_PUBLIC_API_URL as "/api" (relative) so it works through the proxy.
NEXT_PUBLIC_API_URL=/api

# Server-side API URL (used by Next.js server routes and form handlers).
# This must point to the production Railway API when deployed on Vercel.
API_URL=https://playmorrow-api-production.up.railway.app/api

# Canonical site URL for metadata / SEO and absolute links.
NEXT_PUBLIC_SITE_URL=https://playmorrow.vercel.app

# Sentry (error tracking) — use the same DSN for client + server
# NEXT_PUBLIC_SENTRY_DSN=   # public safe DSN for browser
# SENTRY_DSN=              # server DSN (can be same as public or with higher privileges)

# Set to 'true' to use mock API data instead of real backend (dev only).
NEXT_PUBLIC_USE_MOCKS=false
# Analytics (Plausible)
NEXT_PUBLIC_PLAUSIBLE_URL=https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=playmorrow.vercel.app
