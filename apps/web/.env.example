# Base URL of the Playmorrow API (NestJS). Used by the browser/server to fetch data.
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Production: NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Canonical site URL for metadata / SEO.
NEXT_PUBLIC_SITE_URL=https://playmorrow.example
# Production: NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Set to 'true' to use mock API data instead of real backend.
NEXT_PUBLIC_USE_MOCKS=true
