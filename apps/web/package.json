{
  "name": "@playmorrow/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:dev": "PLAYWRIGHT_DEV=1 playwright test",
    "clean-port": "lsof -ti:${PLAYWRIGHT_PORT:-3099} | xargs kill -9 2>/dev/null || true",
    "test:e2e:server": "next dev -p 3099",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:snapshots": "UPDATE_SNAPSHOTS=1 playwright test snapshots.spec.ts --update-snapshots",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "clean": "rm -rf .next .turbo"
  },
  "dependencies": {
    "@playmorrow/types": "workspace:*",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-query": "^5.62.11",
    "@uiw/react-md-editor": "^4.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "^15.1.4",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playmorrow/config": "workspace:*",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-actions": "8.6.18",
    "@storybook/addon-backgrounds": "8.6.18",
    "@storybook/addon-controls": "8.6.18",
    "@storybook/addon-highlight": "8.6.18",
    "@storybook/addon-measure": "8.6.18",
    "@storybook/addon-outline": "8.6.18",
    "@storybook/addon-viewport": "8.6.18",
    "@storybook/nextjs": "10.4.6",
    "@storybook/test": "8.6.18",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "storybook": "10.4.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
