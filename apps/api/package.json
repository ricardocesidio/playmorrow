{
  "name": "@playmorrow/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude='**/*.spec.ts' 2>/dev/null; vitest run src/common/ src/auth/ --reporter=verbose 2>&1 | head -20 || echo 'Run individual spec files instead of full suite — see CONTRIBUTING.md'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db:up": "docker compose -f ../../docker-compose.yml up -d postgres-test",
    "test:db:down": "docker compose -f ../../docker-compose.yml down",
    "test:with-db": "TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/playmorrow_test?schema=public vitest run",
    "clean": "rm -rf dist .turbo",
    "xp:recalculate": "npx ts-node src/scripts/recalculate-xp.ts",
    "devlogs:publish-scheduled": "echo 'Now automatic via DevlogsSchedulerService (@nestjs/schedule cron every 5 min)'",
    "loadtest": "k6 run scripts/load-test.js",
    "seed:model-games": "npx ts-node -r tsconfig-paths/register src/scripts/seed-model-games.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.2",
    "@nestjs/throttler": "^6.5.0",
    "@playmorrow/database": "workspace:*",
    "@playmorrow/types": "workspace:*",
    "@sentry/node": "^10.64.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dompurify": "^3.4.11",
    "express": "^5.1.0",
    "helmet": "^8.2.0",
    "image-size": "^2.0.2",
    "jsdom": "^29.1.1",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.14.0",
    "rxjs": "^7.8.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@playmorrow/config": "workspace:*",
    "@swc/core": "^1.10.7",
    "@types/cookie-parser": "^1.4.7",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.17.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.1.10"
  }
}
