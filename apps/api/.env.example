# API server
PORT=4000
NODE_ENV=development

# Allowed browser origin for CORS (the Next.js web app)
WEB_ORIGIN=http://localhost:3000

# Database (Prisma) — same value as the root .env
DATABASE_URL="postgresql://playmorrow:playmorrow@localhost:5432/playmorrow?schema=public"

# Auth — JWT access token (short-lived) + refresh token (30-day rotation)
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"          # access token expiry — keep short; refresh token handles re-auth

# Session cookie secret (used for signing session cookies)
SESSION_SECRET="change-me-in-production"

# Uploads directory (defaults to apps/api/uploads relative to compiled output)
# UPLOADS_DIR="/app/uploads"

# OAuth (#6) — Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"
# Production: GOOGLE_CALLBACK_URL="https://api.yourdomain.com/api/auth/google/callback"

# OAuth (#6) — GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:4000/api/auth/github/callback"
# Production: GITHUB_CALLBACK_URL="https://api.yourdomain.com/api/auth/github/callback"

# Email (Resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="PlayMorrow <noreply@playmorrow.com>"
EMAIL_CODE_SECRET=
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# Owner admin bootstrap
PLAYMORROW_OWNER_EMAIL=
PLAYMORROW_OWNER_USERNAME=
