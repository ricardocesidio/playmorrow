# API server
PORT=4000
NODE_ENV=development

# Allowed browser origin for CORS (the Next.js web app)
WEB_ORIGIN=http://localhost:3000

# Database (Prisma) — same value as the root .env
DATABASE_URL="postgresql://playmorrow:playmorrow@localhost:5432/playmorrow?schema=public"

# Auth — JWT access token (short-lived) + refresh token (30-day rotation)
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"          # access token expiry — keep short; refresh token handles re-auth
