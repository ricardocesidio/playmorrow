# ──────────────────────────────────────────────────────────────
# Playmorrow — root environment template
# Copy to .env and fill in. Individual apps also have their own
# .env.example (apps/web, apps/api) for app-specific values.
# ──────────────────────────────────────────────────────────────

# Postgres connection string used by Prisma (packages/database) and the API.
# Local Docker default (see docker-compose.yml):
DATABASE_URL="postgresql://playmorrow:playmorrow@localhost:5432/playmorrow?schema=public"
# Hosted alternatives (no Docker needed): Neon or Supabase connection string.

# Node environment
NODE_ENV="development"

# NOTE: The following secrets are REQUIRED in production (Railway):
#   JWT_SECRET, SESSION_SECRET, CSRF_SECRET, RESEND_API_KEY, WEB_ORIGIN
# See apps/api/.env.example for the full list and production values.
# The API now exits immediately on boot in production if any are missing.
