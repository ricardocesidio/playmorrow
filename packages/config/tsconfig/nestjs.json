{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Playmorrow NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": false,
    "noUncheckedIndexedAccess": false,
    "incremental": false
  }
}
